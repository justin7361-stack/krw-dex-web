##
## HyperKRW DEX Frontend — Environment Variables (Q-5)
## Copy: cp .env.example .env.local
## Fill in contract addresses after running: forge script script/DeployTestnet.s.sol --broadcast
##

# ── Server API ────────────────────────────────────────────────────────────────
# Testnet: https://api.hyperkrw.xyz | Local: http://localhost:3000
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# ── HyperEVM Chain ───────────────────────────────────────────────────────────
# 998 = HyperEVM Testnet | 999 = HyperEVM Mainnet
VITE_CHAIN_ID=998

# ── Contract Addresses ────────────────────────────────────────────────────────
# Printed by DeployTestnet.s.sol as "=== .env COPY-PASTE (krw-dex-web) ==="
VITE_ORDER_SETTLEMENT_ADDRESS=0x
VITE_PAIR_REGISTRY_ADDRESS=0x
VITE_MARGIN_REGISTRY_ADDRESS=0x
VITE_HYBRID_POOL_ADDRESS=0x
VITE_KRW_TOKEN_ADDRESS=0x
VITE_USDC_ADDRESS=0x

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Create a project at https://cloud.walletconnect.com (free)
VITE_WALLETCONNECT_PROJECT_ID=

# ── Testnet only: admin API key for self-registration ─────────────────────────
# DO NOT use in production — build a separate key-registration service for mainnet.
VITE_TESTNET_ADMIN_API_KEY=
