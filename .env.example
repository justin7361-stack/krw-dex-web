# HyperKRW DEX — Environment Variables
# Copy this file to .env.local and fill in the values

# Server API
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# HyperEVM Chain
VITE_CHAIN_ID=998

# Contract Addresses (deploy from krw-dex-contracts)
VITE_ORDER_SETTLEMENT_ADDRESS=0x
VITE_PAIR_REGISTRY_ADDRESS=0x
VITE_MARGIN_REGISTRY_ADDRESS=0x
VITE_HYBRID_POOL_ADDRESS=0x
VITE_KRW_TOKEN_ADDRESS=0x

# WalletConnect (get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# Testnet only — admin API key for self-registration of trading API keys
# WARNING: DO NOT use in production. Build a separate key-registration server for mainnet.
VITE_TESTNET_ADMIN_API_KEY=
